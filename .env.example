# Copy to .env (already gitignored) and fill in real values. Never commit .env.

QUIZ_BASE_URL=https://stage.allright.com

# Grab this from the Authorization header of any request made from the
# admin panel (Network tab -> any admin/api/* call -> Headers -> Authorization).
# Do not paste it into chat, docs, or commit messages.
ADMIN_BEARER_TOKEN=

# Only needed if the admin API lives on a different host than the app itself.
ADMIN_API_BASE_URL=https://stage.allright.com
